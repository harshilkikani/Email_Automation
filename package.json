{
  "name": "keres-ai",
  "private": true,
  "version": "0.1.0",
  "description": "Keres AI — internal lead-gen + cold email validation console",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "postinstall": "node -e \"if(require('fs').existsSync('.git')){require('child_process').execSync('sh scripts/install-hooks.sh',{stdio:'inherit'})}\"",
    "build": "pnpm -r --filter=\"./packages/**\" run build && pnpm -r --filter=\"./apps/**\" run build",
    "dev": "concurrently -n server,web -c green,cyan \"pnpm --filter @keres/server dev\" \"pnpm --filter @keres/web dev\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:test": "vitest run --config vitest.integration.config.ts",
    "doctor": "tsx scripts/doctor.ts",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "db:generate": "pnpm --filter @keres/db generate",
    "db:migrate": "pnpm --filter @keres/db migrate",
    "db:seed": "pnpm --filter @keres/server seed",
    "start": "pnpm --filter @keres/server start",
    "preflight:local": "tsx scripts/preflight-local.ts",
    "preflight:deploy": "tsx scripts/preflight-deploy.ts",
    "secrets:gen": "tsx scripts/generate-secrets.ts",
    "domain:plan": "tsx scripts/domain-plan.ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/pg": "^8.11.6",
    "concurrently": "^8.2.2",
    "eslint": "^10.4.0",
    "pg": "^8.12.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.16.0",
    "undici": "^6.19.5",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@9.7.0"
}
