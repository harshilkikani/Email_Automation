{
  "name": "keres-ai",
  "private": true,
  "version": "0.1.0",
  "description": "Keres AI — internal lead-gen + cold email validation console",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r --filter=\"./packages/**\" run build && pnpm -r --filter=\"./apps/**\" run build",
    "dev": "concurrently -n server,web -c green,cyan \"pnpm --filter @keres/server dev\" \"pnpm --filter @keres/web dev\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:test": "vitest run --config vitest.integration.config.ts",
    "doctor": "tsx scripts/doctor.ts",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "db:generate": "pnpm --filter @keres/db generate",
    "db:migrate": "pnpm --filter @keres/db migrate",
    "db:seed": "pnpm --filter @keres/server seed",
    "start": "pnpm --filter @keres/server start"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/pg": "^8.11.6",
    "concurrently": "^8.2.2",
    "pg": "^8.12.0",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4",
    "undici": "^6.19.5",
    "vitest": "^1.6.0"
  },
  "packageManager": "pnpm@9.7.0"
}
