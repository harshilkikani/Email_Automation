{
  "name": "@keres/email",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/email/src/index.js",
  "types": "dist/email/src/index.d.ts",
  "exports": {
    ".":             { "types": "./dist/email/src/index.d.ts",       "default": "./dist/email/src/index.js" },
    "./render":      { "types": "./dist/email/src/render.d.ts",      "default": "./dist/email/src/render.js" },
    "./headers":     { "types": "./dist/email/src/headers.d.ts",     "default": "./dist/email/src/headers.js" },
    "./unsubscribe": { "types": "./dist/email/src/unsubscribe.d.ts", "default": "./dist/email/src/unsubscribe.js" },
    "./linter":      { "types": "./dist/email/src/linter.d.ts",      "default": "./dist/email/src/linter.js" }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@keres/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
