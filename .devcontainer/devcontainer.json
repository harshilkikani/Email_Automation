{
  "name": "Keres AI",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "forwardPorts": [8080, 5173, 5432],
  "portsAttributes": {
    "5173": { "label": "Web UI", "onAutoForward": "openBrowser" },
    "8080": { "label": "API server" },
    "5432": { "label": "Postgres" }
  },
  "postCreateCommand": "npm install -g pnpm@9.7.0 && pnpm install && cp .env.example .env && docker compose up -d postgres && sleep 5 && pnpm db:migrate && pnpm db:seed",
  "remoteEnv": {
    "SAMPLE_MODE": "true"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  }
}
