# ─────────────────────────────────────────────────────────────────
# Keres AI — production env reference (paste values into your secrets
# store, NEVER into chat). This file is committed only as a TEMPLATE.
#
# Recommended flow:
#   1. pnpm secrets:gen --quiet > /tmp/k.secrets.txt
#   2. open /tmp/k.secrets.txt in your editor
#   3. paste the AUTH_TOKEN / AUTH_COOKIE_SECRET / UNSUBSCRIBE_SIGNING_SECRET
#      values into 1Password or your password manager
#   4. shred /tmp/k.secrets.txt
#   5. paste each value into `flyctl secrets set NAME='<value>'`
#   6. never reuse a dev .env in production
# ─────────────────────────────────────────────────────────────────

# ── Mode / runtime ────────────────────────────────────────────────
NODE_ENV=production
SAMPLE_MODE=false                     # MUST be false in production
BUDGET_MODE=free
PORT=8080
PUBLIC_BASE_URL=https://keres-ops.fly.dev  # HTTPS required in production
SERVE_WEB=true                        # serve SPA from API process
LOG_LEVEL=info

# ── Database (Neon free tier in prod) ─────────────────────────────
# Use the POOLED connection string ending in `-pooler.<region>.neon.tech`.
DATABASE_URL=
DATABASE_DRIVER=neon-serverless       # node|neon-serverless

# ── Auth (192-bit random each, generated locally) ─────────────────
AUTH_TOKEN=
AUTH_COOKIE_NAME=keres_session
AUTH_COOKIE_SECRET=
UNSUBSCRIBE_SIGNING_SECRET=
CORS_ORIGIN=https://keres-ops.fly.dev

# ── Sender identity (CAN-SPAM REQUIRED) ───────────────────────────
ORG_NAME=Keres AI
FROM_NAME=Keres AI Outreach
FROM_EMAIL=hello@outreach.keresai.com
REPLY_TO=replies@outreach.keresai.com
PHYSICAL_ADDRESS=                     # REAL street address required by CAN-SPAM
OUTREACH_SUBDOMAIN=outreach.keresai.com
DEFAULT_BOOKING_LINK=

# ── Outbound — START WITH SES OFF ─────────────────────────────────
# Leave ENABLE_SES=false until your SES production-access ticket is approved
# AND you've toggled SES_PRODUCTION_ACCESS_CONFIRMED=true.
# Launch gate refuses every send while these are not set together.
ENABLE_SES=false
SES_REGION=us-east-1
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
SES_CONFIGURATION_SET=keres-outreach
SES_SNS_TOPIC_ARN=
SES_PRODUCTION_ACCESS_CONFIRMED=false

# ── Inbound (Postmark — inbound only, never outbound for cold) ────
ENABLE_POSTMARK_INBOUND=false
POSTMARK_INBOUND_TOKEN=
POSTMARK_INBOUND_USERNAME=
POSTMARK_INBOUND_PASSWORD=
INBOUND_ADDRESS=replies@outreach.keresai.com

# ── Discovery providers ───────────────────────────────────────────
ENABLE_OSM=true
OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter
OSM_USER_AGENT=KeresAI/1.0 (your-real-email@yourdomain.com)
OSM_CONTACT_EMAIL=your-real-email@yourdomain.com

ENABLE_YELP=false                     # Optional gap-fill (no-store rule enforced)
YELP_API_KEY=
YELP_MONTHLY_BUDGET_USD=0

ENABLE_PLACES=false                   # Disabled at MVP — do not enable
PLACES_API_KEY=
PLACES_MONTHLY_BUDGET_USD=0

# ── Verification providers (paid fallbacks) ───────────────────────
ENABLE_HUNTER=false                   # Free 50/mo; only for score>=95 + scrape failed
HUNTER_API_KEY=
HUNTER_MONTHLY_FREE_CREDITS=50

ENABLE_BOUNCER=false                  # PAYG $8/1k; only for score>=80 + ambiguous
BOUNCER_API_KEY=
BOUNCER_MONTHLY_BUDGET_USD=5

# ── Operational ───────────────────────────────────────────────────
SEEDLIST_EMAILS=                      # comma-separated; at least 1 mailbox you control
BOUNCE_PAUSE_PCT=4                    # auto-pause at this 24h bounce %
COMPLAINT_PAUSE_PCT=0.1               # auto-pause at this 24h complaint %
DAILY_SEND_CAP_DEFAULT=50

# Cron refresh schedules (Cloudflare Cron Triggers run these, server reads as documentation)
NOAA_STORM_REFRESH_CRON=0 4 1 * *
CENSUS_CBP_REFRESH_CRON=0 4 1 1 *
