# ───────────────────────────────────────────────────────────────────
# Keres AI — environment configuration
# Copy this to `.env` for local dev. Never commit `.env` to git.
# ───────────────────────────────────────────────────────────────────

# ── Mode / runtime ────────────────────────────────────────────────
NODE_ENV=development
SAMPLE_MODE=true                # When true: discovery + send use in-memory mocks
BUDGET_MODE=free                # free | low | normal — gates paid provider calls
PORT=8080
WEB_PORT=5173
PUBLIC_BASE_URL=http://localhost:8080

# ── Database ──────────────────────────────────────────────────────
# Local dev: a vanilla Postgres URL (`postgres:postgres@localhost:5432/keres`).
# Production: a Neon URL (use the pooled `*-pooler.<region>.neon.tech` host with `?sslmode=require`).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/keres
DATABASE_DRIVER=node            # node | neon-serverless

# ── Single-tenant auth ────────────────────────────────────────────
# Generate strong values with `pnpm secrets:gen` (never paste them in chat).
AUTH_TOKEN=change-me-to-a-long-random-string
AUTH_COOKIE_NAME=keres_session
AUTH_COOKIE_SECRET=change-me-to-another-long-random-string
# Separate signing key for unsubscribe + seedlist tokens (defense-in-depth).
# If unset, falls back to AUTH_COOKIE_SECRET (backwards-compatible).
UNSUBSCRIBE_SIGNING_SECRET=

# CORS allowlist for production (comma-separated). Empty = derive from PUBLIC_BASE_URL.
CORS_ORIGIN=

# ── Sender identity (Settings) ────────────────────────────────────
ORG_NAME=Keres AI
FROM_NAME=Keres AI Outreach
FROM_EMAIL=hello@outreach.keresai.com
REPLY_TO=replies@outreach.keresai.com
PHYSICAL_ADDRESS=Keres AI, 1 Example St, Austin TX 78701
OUTREACH_SUBDOMAIN=outreach.keresai.com

# ── AWS SES (outbound) ────────────────────────────────────────────
ENABLE_SES=false
SES_REGION=us-east-1
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
SES_CONFIGURATION_SET=keres-outreach
SES_SNS_TOPIC_ARN=
SES_PRODUCTION_ACCESS_CONFIRMED=false

# ── Postmark Inbound ──────────────────────────────────────────────
ENABLE_POSTMARK_INBOUND=false
POSTMARK_INBOUND_TOKEN=
POSTMARK_INBOUND_USERNAME=
POSTMARK_INBOUND_PASSWORD=
INBOUND_ADDRESS=replies@outreach.keresai.com

# ── Discovery providers ───────────────────────────────────────────
ENABLE_OSM=true
OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter
OSM_USER_AGENT=KeresAI/0.1 (ops@keresai.com)
OSM_CONTACT_EMAIL=ops@keresai.com

ENABLE_YELP=false
YELP_API_KEY=
YELP_MONTHLY_BUDGET_USD=0       # 0 = free tier only

ENABLE_PLACES=false             # Disabled at MVP — kept for future
PLACES_API_KEY=
PLACES_MONTHLY_BUDGET_USD=0

# ── Verification providers ────────────────────────────────────────
ENABLE_HUNTER=false
HUNTER_API_KEY=
HUNTER_MONTHLY_FREE_CREDITS=50  # 2026 unified-credit free tier

ENABLE_BOUNCER=false
BOUNCER_API_KEY=
BOUNCER_MONTHLY_BUDGET_USD=5

# ── External data caches ──────────────────────────────────────────
NOAA_STORM_REFRESH_CRON=0 4 1 * *      # 4am UTC on the 1st of each month
CENSUS_CBP_REFRESH_CRON=0 4 1 1 *      # 4am UTC on Jan 1

# ── Seedlist (validation mode) ────────────────────────────────────
SEEDLIST_EMAILS=seed1@yourdomain.com,seed2@gmail.com,seed3@outlook.com

# ── Default booking link rendered into templates ──────────────────
DEFAULT_BOOKING_LINK=https://cal.keresai.com/intro

# ── Compliance / send safety thresholds ───────────────────────────
BOUNCE_PAUSE_PCT=4              # auto-pause campaign at this 24h bounce %
COMPLAINT_PAUSE_PCT=0.1         # auto-pause campaign at this 24h complaint %
DAILY_SEND_CAP_DEFAULT=50

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Single-process deploy (serve SPA from API) ────────────────────
# When SERVE_WEB=true, the API also serves apps/web/dist on / so one Fly
# machine runs everything. Leave false in dev (Vite serves the SPA on :5173).
SERVE_WEB=false
WEB_DIST_PATH=
